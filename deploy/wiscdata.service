[Unit]
Description=WiscData Salary Explorer (Streamlit)
After=network.target

[Service]
Type=simple
User=wiscdata
Group=wiscdata
WorkingDirectory=/opt/wiscdata/app
ExecStart=/opt/wiscdata/venv/bin/streamlit run salary_app.py \
    --server.port 8501 \
    --server.address 127.0.0.1 \
    --server.headless true \
    --browser.gatherUsageStats false
Restart=always
RestartSec=5

# Memory limit — kill and restart if it exceeds 1.5GB
MemoryMax=1536M

[Install]
WantedBy=multi-user.target
